# Application
NODE_ENV=development
PORT=3000
APP_NAME=video-studio-api
ENABLE_PLAYGROUND_UI=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/video_generation
# For authenticated MongoDB:  mongodb://user:password@localhost:27017/video_generation
# For MongoDB Atlas:           mongodb+srv://user:password@cluster.mongodb.net/video_generation

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_ORG_ID=

# Script Generation Provider
# Options: openai, claude, ollama, together-ai
SCRIPT_PROVIDER=openai
SCRIPT_MODEL=gpt-4o

# Image Generation Provider
# Options: dalle, stable-diffusion, leonardo, together-ai
IMAGE_PROVIDER=dalle
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1024x1024

# TTS Provider
# Options: openai, elevenlabs, google-tts, coqui, edge-tts
TTS_PROVIDER=openai
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Microsoft Edge TTS (no API key required — free, uses Edge Read Aloud service)
# Common voices: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural, en-AU-NatashaNeural
# Full list: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/language-support
EDGE_TTS_VOICE=en-US-AriaNeural

# Alternative Providers (Optional)
# Anthropic Claude
CLAUDE_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=

# Replicate (for Stable Diffusion)
REPLICATE_API_KEY=

# TogetherAI (for script and image generation — https://api.together.xyz)
# Default script model: meta-llama/Llama-3.3-70B-Instruct-Turbo
# Default image model: black-forest-labs/FLUX.1-schnell
TOGETHER_API_KEY=

# Video Configuration
DEFAULT_VIDEO_RESOLUTION=1080p
DEFAULT_VIDEO_FPS=30
DEFAULT_VIDEO_CODEC=h264
MAX_VIDEO_DURATION=600
MIN_VIDEO_DURATION=15

# Storage Configuration
STORAGE_PROVIDER=local
# Options: local, s3, cloudflare_r2, oracle_s3
LOCAL_STORAGE_PATH=./storage
TEMP_STORAGE_PATH=./temp

# AWS S3 Configuration (if STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=video-generation-videos

# Cloudflare R2 Configuration (if STORAGE_PROVIDER=cloudflare_r2)
CF_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=video-generation-videos
CF_R2_PUBLIC_URL=       # optional: custom domain or r2.dev public URL

# Oracle Cloud Object Storage (if STORAGE_PROVIDER=oracle_s3)
OCI_NAMESPACE=          # Object Storage namespace (tenancy name)
OCI_REGION=us-ashburn-1
OCI_S3_ACCESS_KEY=
OCI_S3_SECRET_KEY=
OCI_S3_BUCKET=video-generation-videos
OCI_S3_PUBLIC_URL=      # optional: CDN or pre-authenticated base URL

# Queue Configuration
QUEUE_CONCURRENCY=2
QUEUE_MAX_RETRIES=3
QUEUE_BACKOFF_DELAY=5000
QUEUE_LOCK_DURATION_MS=300000
QUEUE_STALLED_INTERVAL_MS=30000
QUEUE_MAX_STALLED_COUNT=3

# Cache Configuration
CACHE_TTL_SCRIPTS=2592000
CACHE_TTL_IMAGES=604800
CACHE_TTL_AUDIO=604800

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
# Options: debug, info, warn, error

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
