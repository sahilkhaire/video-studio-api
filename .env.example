# Application
NODE_ENV=development
PORT=3000
APP_NAME=video-generation-poc

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=video_generation
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_ORG_ID=

# Script Generation Provider
# Options: openai, claude, ollama
SCRIPT_PROVIDER=openai
SCRIPT_MODEL=gpt-4

# Image Generation Provider
# Options: dalle, stable-diffusion, leonardo
IMAGE_PROVIDER=dalle
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1024x1024

# TTS Provider
# Options: openai, elevenlabs, google-tts, coqui
TTS_PROVIDER=openai
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Alternative Providers (Optional)
# Anthropic Claude
CLAUDE_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=

# Replicate (for Stable Diffusion)
REPLICATE_API_KEY=

# Video Configuration
DEFAULT_VIDEO_RESOLUTION=1080p
DEFAULT_VIDEO_FPS=30
DEFAULT_VIDEO_CODEC=h264
MAX_VIDEO_DURATION=600
MIN_VIDEO_DURATION=15

# Storage Configuration
STORAGE_PROVIDER=local
# Options: local, s3
LOCAL_STORAGE_PATH=./storage
TEMP_STORAGE_PATH=./temp

# AWS S3 Configuration (if STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=video-generation-videos

# Queue Configuration
QUEUE_CONCURRENCY=2
QUEUE_MAX_RETRIES=3
QUEUE_BACKOFF_DELAY=5000

# Cache Configuration
CACHE_TTL_SCRIPTS=2592000
CACHE_TTL_IMAGES=604800
CACHE_TTL_AUDIO=604800

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
# Options: debug, info, warn, error

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
